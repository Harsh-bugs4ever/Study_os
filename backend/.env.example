DATABASE_URL=postgresql+psycopg://studyos:studyos@localhost:5432/studyos
JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_EXPIRY_SECONDS=3600
REFRESH_EXPIRY_DAYS=30
CORS_ORIGINS=http://localhost:5173
PUBLIC_URL=http://localhost:8000
STORAGE_PATH=./storage
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
SESSION_SECRET=replace-with-another-random-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Cognee: relational state and embeddings use a separate database on the same
# PostgreSQL server to avoid collisions with StudyOS application tables.
COGNEE_ENABLED=true
COGNEE_DATASET_PREFIX=studyos
DB_PROVIDER=postgres
DB_NAME=cognee
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=studyos
DB_PASSWORD=studyos
VECTOR_DB_PROVIDER=pgvector
VECTOR_DATASET_DATABASE_HANDLER=pgvector
VECTOR_DB_NAME=cognee
VECTOR_DB_URL=127.0.0.1
VECTOR_DB_PORT=5432
VECTOR_DB_USERNAME=studyos
VECTOR_DB_PASSWORD=studyos
GRAPH_DATABASE_PROVIDER=kuzu
SYSTEM_ROOT_DIRECTORY=./.cognee_system
ENABLE_BACKEND_ACCESS_CONTROL=false
LLM_API_KEY=
LLM_MODEL=groq/llama-3.3-70b-versatile
