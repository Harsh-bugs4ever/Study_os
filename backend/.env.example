DATABASE_URL=postgresql://postgres:Studyoskijai@321@db.dsyuxqvbrhynxkrqfqmw.supabase.co:5432/postgres
JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_EXPIRY_SECONDS=3600
REFRESH_EXPIRY_DAYS=30
CORS_ORIGINS=http://localhost:5173
PUBLIC_URL=http://localhost:8000
STORAGE_PATH=./storage
SESSION_SECRET=replace-with-another-random-secret

# ── Google / Gemini AI ──────────────────────────────────────────────────────
GOOGLE_AI_API_KEY=
AI_GATEWAY_URL=https://generativelanguage.googleapis.com/v1beta
AI_MODEL=gemini-2.5-flash

# ── Groq (alternative — faster, free tier available) ────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Provider selection ───────────────────────────────────────────────────────
# auto  → Groq if GROQ_API_KEY is set, otherwise Gemini
# groq  → always use Groq
# gemini → always use Gemini
AI_PROVIDER=auto

# ── OAuth ───────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Cognee (relational memory + embeddings) ──────────────────────────────────
# Uses a separate PostgreSQL database to avoid collisions with app tables.
COGNEE_ENABLED=true
COGNEE_DATASET_PREFIX=studyos
DB_PROVIDER=postgres
DB_NAME=cognee
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=studyos
DB_PASSWORD=studyos
VECTOR_DB_PROVIDER=pgvector
VECTOR_DATASET_DATABASE_HANDLER=pgvector
VECTOR_DB_NAME=cognee
VECTOR_DB_URL=127.0.0.1
VECTOR_DB_PORT=5432
VECTOR_DB_USERNAME=studyos
VECTOR_DB_PASSWORD=studyos
GRAPH_DATABASE_PROVIDER=kuzu
SYSTEM_ROOT_DIRECTORY=./.cognee_system
ENABLE_BACKEND_ACCESS_CONTROL=false

# Cognee LLM (separate from the main AI provider above)
LLM_API_KEY=
LLM_MODEL=gemini/gemini-2.5-flash
