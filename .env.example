# ─────────────────────────────────────────────────────────────────
# StudyOS — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your real .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your project's REST API base URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (safe to expose in the browser)
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# ── GitHub OAuth (direct — no Supabase provider config needed) ────
# From: github.com/settings/developers → OAuth Apps → your app
# Only the CLIENT_ID goes here (public). The CLIENT_SECRET goes into
# Supabase Edge Function secrets as GITHUB_CLIENT_SECRET.
VITE_GITHUB_CLIENT_ID=your-github-oauth-app-client-id

# ── Supabase Edge Function Secrets ────────────────────────────────
# Set these in Supabase Dashboard → Edge Functions → Secrets
# (these are NOT used in the frontend — server-side only)
#
# LOVABLE_API_KEY=your-lovable-or-openai-api-key

# ── Optional / Not currently used by client code ─────────────────
# VITE_SUPABASE_SECRET_KEY is the service_role key — never expose
# it in a browser. Only needed for admin server-side scripts.
# VITE_SUPABASE_SECRET_KEY=your-service-role-key

# VITE_SUPABASE_JWKS_URL is auto-derived from VITE_SUPABASE_URL.
# Only override if you have a custom auth setup.
# VITE_SUPABASE_JWKS_URL=https://your-project-id.supabase.co/auth/v1/.well-known/jwks.json
